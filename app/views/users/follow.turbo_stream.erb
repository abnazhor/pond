<turbo-stream action="replace" target="<%= dom_id(@user, :follow_btn) %>">
  <template>
    <%= render Components::FollowBtn.new(followable: @user) %>
  </template>
</turbo-stream>

<turbo-stream action="toast" target="ruby-ui-toaster" variant="success" title="Good!" description="You are now following <%= @user.to_s %>">
  <template></template>
</turbo-stream>
