<turbo-stream action="toast" target="ruby-ui-toaster" variant="error" title="Error" description="<%= @pin.errors.full_messages&.to_sentence %>">
  <template></template>
</turbo-stream>

<turbo-stream action="replace" target="post-form">
  <template>
    <%= render Components::Posts::Form.new(pin: @pin) %>
  </template>
</turbo-stream>
